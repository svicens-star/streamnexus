# Copiá este archivo a android/keystore.properties y completá los valores.
# NUNCA subas keystore.properties ni el .jks al repositorio.
#
# Generá el almacén con: npm run mobile:android:keystore
# (o keytool manual; ver scripts/create-android-keystore.mjs)

storePassword=TU_CLAVE_DEL_ALMACEN
keyPassword=TU_CLAVE_DE_LA_CLAVE
keyAlias=upload
storeFile=../upload-keystore.jks
